{
  "name": "event-catalogue",
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*",
    "#catalog/*": "./catalog/*"
  },
  "scripts": {
    "build": "eve build",
    "dev": "eve dev --no-ui",
    "start": "eve start",
    "typecheck": "tsc",
    "test": "node --env-file-if-exists=.env.local --test catalog/*.test.ts catalog/providers/*.test.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/api-logs": "0.220.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.220.0",
    "@opentelemetry/instrumentation": "0.220.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-logs": "0.220.0",
    "@opentelemetry/sdk-metrics": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@upstash/redis": "1.38.0",
    "@vercel/connect": "0.2.2",
    "@vercel/otel": "2.1.3",
    "ai": "^7.0.0",
    "ajv": "8.20.0",
    "eve": "0.22.5",
    "langsmith": "0.8.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "microsandbox": "^0.6.6",
    "typescript": "7.0.2"
  },
  "overrides": {
    "ai": "^7.0.0"
  },
  "engines": {
    "node": "24.x"
  }
}
