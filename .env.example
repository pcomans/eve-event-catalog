# Alpaca paper trading (https://alpaca.markets/)
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
# Market data feed for the price.crossesBelow/crossesAbove watcher (catalog/providers/alpaca.ts):
# "iex" (default) is the real feed — only ticks during US market hours (9:30-16:00 ET, Mon-Fri).
# "test" switches to Alpaca's 24/7 synthetic FAKEPACA feed for off-hours development; same wire
# protocol, only the symbol and stream URL differ. Requires a process restart to change.
ALPACA_DATA_FEED=iex

# SEC EDGAR requires a descriptive User-Agent: "<name> <email>"
EDGAR_USER_AGENT=

# LangSmith tracing (https://smith.langchain.com/), wired via agent/instrumentation.ts
# using langsmith's OTel exporter (LangSmithOTLPTraceExporter). Required:
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
# LANGSMITH_TRACING must be the literal string "true", or the exporter is a silent
# no-op — it checks this before ever sending spans, with no error either way.
LANGSMITH_TRACING=true

# Model access via Vercel AI Gateway. Locally, `vercel link` + `vercel env pull`
# populates VERCEL_OIDC_TOKEN in .env.local instead, which also satisfies this.
AI_GATEWAY_API_KEY=

# Catalog registry + conversation map (Upstash Redis via Vercel Marketplace:
# `vercel integration add upstash/upstash-kv`, then `vercel env pull`).
# @upstash/redis reads either naming convention; only one pair is needed.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Base URL catalog/wake.ts uses to loop back into this same dev server's own
# POST /catalog/wake route when delivering a wake (expiry timers, provider
# ticks). Defaults to http://localhost:$PORT (PORT itself defaults to 2000)
# — only set this if you run the dev server on a non-default port or host.
# CATALOG_BASE_URL=http://localhost:2000
